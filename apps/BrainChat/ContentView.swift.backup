import AppKit
import SwiftUI

struct ContentView: View {
    @EnvironmentObject var store: ConversationStore
    @EnvironmentObject var speechManager: SpeechManager
    @EnvironmentObject var voiceManager: VoiceManager
    @EnvironmentObject var settings: AppSettings
    @EnvironmentObject var llmRouter: LLMRouter

    @StateObject private var viewModel = ChatViewModel()
    @State private var showClearConfirmation = false
    @State private var showKeyboardHelp = false
    @State private var messageHistoryIndex: Int = -1
    @State private var messageHistory: [String] = []
    @FocusState private var isTextFieldFocused: Bool
    @FocusState private var focusTarget: FocusTarget?
    
    enum FocusTarget {
        case chatArea
        case inputField
        case controls
    }

    var body: some View {
        VStack(spacing: 0) {
            toolbar
                .accessibilityIdentifier("statusSection")
                .accessibilityLabel("Status and controls")
                .focused($focusTarget, equals: .controls)
            Divider()
            ConversationView()
                .environmentObject(viewModel.layeredMessageStore)
                .frame(maxWidth: .infinity, maxHeight: .infinity)
                .accessibilityIdentifier("conversationSection")
                .focused($focusTarget, equals: .chatArea)
            YoloActionFeed(yolo: viewModel.yolo)
            Divider()

            if viewModel.isMicLive && !viewModel.liveTranscript.isEmpty {
                liveTranscriptView
            }

            inputBar
        }
        .overlay {
            if viewModel.yolo.pendingConfirmation != nil {
                ZStack {
                    Color.black.opacity(0.15)
                        .ignoresSafeArea()
                    YoloConfirmationDialog(yolo: viewModel.yolo)
                        .frame(maxWidth: 360)
                }
            }
            
            if showKeyboardHelp {
                KeyboardShortcutsHelpOverlay(isPresented: $showKeyboardHelp)
            }
        }
        .onAppear {
            viewModel.configure(
                store: store,
                speechManager: speechManager,
                voiceManager: voiceManager,
                settings: settings,
                llmRouter: llmRouter
            )
            viewModel.handleAppear()
            isTextFieldFocused = true
            focusTarget = .inputField
        }
        .onDisappear {
            viewModel.handleDisappear()
        }
        .onChange(of: viewModel.error) { _, error in
            guard let error else { return }
            postAccessibilityAnnouncement(error, priority: NSAccessibilityPriorityLevel.high.rawValue)
        }
        .onKeyPress("n", modifiers: .command) {
            newConversation()
            return .handled
        }
        .onKeyPress("k", modifiers: .command) {
            showClearConfirmation = true
            return .handled
        }
        .onKeyPress("1", modifiers: .command) {
            focusTarget = .chatArea
            postAccessibilityAnnouncement("Focused on conversation area", priority: NSAccessibilityPriorityLevel.high.rawValue)
            return .handled
        }
        .onKeyPress("2", modifiers: .command) {
            focusTarget = .inputField
            isTextFieldFocused = true
            postAccessibilityAnnouncement("Focused on message input field", priority: NSAccessibilityPriorityLevel.high.rawValue)
            return .handled
        }
        .onKeyPress("3", modifiers: .command) {
            focusTarget = .controls
            postAccessibilityAnnouncement("Focused on controls", priority: NSAccessibilityPriorityLevel.high.rawValue)
            return .handled
        }
        .onKeyPress("m", modifiers: .command) {
            viewModel.toggleMic()
            let status = viewModel.isMicLive ? "Microphone now live" : "Microphone now muted"
            postAccessibilityAnnouncement(status, priority: NSAccessibilityPriorityLevel.high.rawValue)
            return .handled
        }
        .onKeyPress("r", modifiers: .command) {
            repeatLastResponse()
            return .handled
        }
        .onKeyPress(.upArrow, modifiers: .command) {
            previousMessage()
            return .handled
        }
        .onKeyPress(.downArrow, modifiers: .command) {
            nextMessage()
            return .handled
        }
        .onKeyPress(.slash, modifiers: .command) {
            showKeyboardHelp = true
            postAccessibilityAnnouncement("Opened keyboard shortcuts help", priority: NSAccessibilityPriorityLevel.high.rawValue)
            return .handled
        }
        .onKeyPress("?", modifiers: .command) {
            showKeyboardHelp = true
            postAccessibilityAnnouncement("Opened keyboard shortcuts help", priority: NSAccessibilityPriorityLevel.high.rawValue)
            return .handled
        }
    }

    private var toolbar: some View {
        HStack(spacing: 8) {
            // MARK: LLM and Configuration Group
            VStack(spacing: 0) {
                LLMSelector()
                    .environmentObject(llmRouter)
                    .environmentObject(settings)

                YoloModeSelector(yolo: viewModel.yolo) { enabled in
                    viewModel.setYoloEnabled(enabled)
                }

                SpeechEngineSelector()
                    .environmentObject(settings)
                    .environmentObject(speechManager)
            }
            .accessibilityElement(children: .contain)
            .accessibilityLabel("Model and engine selection")
            .accessibilityIdentifier("configurationGroup")

            Spacer()

            // MARK: Status Group - Session and Audio
            VStack(spacing: 0) {
                YoloStatusBadge(yolo: viewModel.yolo)

                HStack(spacing: 4) {
                    Image(systemName: viewModel.isCopilotSessionActive ? "bolt.horizontal.circle.fill" : "bolt.horizontal.circle")
                        .foregroundColor(viewModel.isCopilotSessionActive ? .blue : .secondary)
                    Text(viewModel.copilotStatusText)
                        .font(.caption)
                        .foregroundColor(.secondary)
                }
                .accessibilityElement(children: .combine)
                .accessibilityShortLabel("Session: \(viewModel.copilotStatusText)")
                .accessibilityIdentifier(AccessibilitySectionID.copilotStatus)

                ProgressView(value: Double(speechManager.audioLevel), total: 1)
                    .frame(width: 56)
                    .accessibilityIdentifier(AccessibilitySectionID.audioLevelGroup)
                    .accessibilityShortLabel("Input level")
                    .accessibilityValue(AudioLevelAccessibility.describe(level: speechManager.audioLevel))
            }
            .accessibilityElement(children: .contain)
            .accessibilityLabel("Status indicators")
            .accessibilityIdentifier("statusGroup")

            // MARK: Control Group - Microphone, Stop, Settings
            HStack(spacing: 8) {
                Button(action: viewModel.toggleMic) {
                    HStack(spacing: 4) {
                        Image(systemName: viewModel.isMicLive ? "mic.fill" : "mic.slash.fill")
                            .foregroundColor(viewModel.isMicLive ? .green : .red)
                        Text(viewModel.isMicLive ? "Live" : "Muted")
                            .font(.caption)
                    }
                    .padding(.horizontal, 8)
                    .padding(.vertical, 4)
                    .background(viewModel.isMicLive ? Color.green.opacity(0.2) : Color.red.opacity(0.2))
                    .cornerRadius(8)
                }
                .buttonStyle(.plain)
                .keyboardShortcut("l", modifiers: .command)
                .keyboardShortcut("m", modifiers: .command)
                .accessibilityIdentifier("microphoneButton")
                .accessibilityShortLabel(viewModel.isMicLive ? AccessibleButtonLabels.micLive : AccessibleButtonLabels.micMuted)
                .accessibilityHint(AccessibleButtonLabels.micHint)
                .accessibilityAddTraits(.isButton)
                .focusable()

                Button(action: voiceManager.stop) {
                    Image(systemName: "speaker.slash.fill")
                }
                .buttonStyle(.plain)
                .keyboardShortcut(".", modifiers: .command)
                .accessibilityIdentifier("stopButton")
                .accessibilityShortLabel(AccessibleButtonLabels.stopSpeaking)
                .accessibilityValue(voiceManager.isSpeaking ? AccessibleButtonLabels.speaking : AccessibleButtonLabels.idle)
                .accessibilityHint(AccessibleButtonLabels.stopHint)

                Button(action: openSettings) {
                    Image(systemName: "gearshape")
                }
                .buttonStyle(.plain)
                .keyboardShortcut(",", modifiers: .command)
                .accessibilityIdentifier("settingsButton")
                .accessibilityShortLabel(AccessibleButtonLabels.settings)
                .accessibilityHint(AccessibleButtonLabels.settingsHint)

                Button(action: { showClearConfirmation = true }) {
                    Image(systemName: "trash")
                }
                .buttonStyle(.plain)
                .keyboardShortcut("k", modifiers: .command)
                .accessibilityIdentifier("clearButton")
                .accessibilityShortLabel(AccessibleButtonLabels.clearChat)
                .accessibilityHint(AccessibleButtonLabels.clearHint)
                .confirmationDialog(
                    "Clear all messages?",
                    isPresented: $showClearConfirmation,
                    titleVisibility: .visible
                ) {
                    Button("Clear Conversation", role: .destructive) {
                        viewModel.clearConversation()
                        messageHistory.removeAll()
                        messageHistoryIndex = -1
                        AccessibilityHelpers.announceHighPriority("Conversation cleared")
                    }
                    Button("Cancel", role: .cancel) {}
                } message: {
                    Text("This will permanently delete all messages in this conversation.")
                }
            }
            .accessibilityElement(children: .contain)
            .accessibilityLabel("Control buttons")
            .accessibilityIdentifier(AccessibilitySectionID.controlsGroup)
        }
            
            Button(action: { showKeyboardHelp = true }) {
                Image(systemName: "questionmark.circle")
            }
            .buttonStyle(.plain)
            .accessibilityIdentifier("helpButton")
            .accessibilityLabel("Show keyboard shortcuts help")
            .accessibilityHint("Shows all available keyboard shortcuts. Press Cmd+? or Cmd+/ to trigger.")
        }
        .padding(12)
    }

    private var liveTranscriptView: some View {
        HStack {
            Text("Hearing: \(viewModel.liveTranscript)")
                .font(.caption)
                .foregroundColor(.secondary)
            Spacer()
        }
        .padding(.horizontal, 12)
        .padding(.vertical, 4)
        .background(Color.green.opacity(0.1))
        .accessibilityElement(children: .combine)
        .accessibilityShortLabel("Live transcript")
        .accessibilityValue(viewModel.liveTranscript)
        .accessibilityHint("Real-time speech recognition. Updates as you speak.")
        .accessibilityIdentifier(AccessibilitySectionID.liveTranscript)
        .accessibilityAddTraits(.updatesFrequently)
    }

    private var inputBar: some View {
        HStack(spacing: 10) {
            TextField("Type a message…", text: $viewModel.inputText)
                .textFieldStyle(.roundedBorder)
                .focused($isTextFieldFocused)
                .focused($focusTarget, equals: .inputField)
                .onSubmit { sendCurrentInput() }
                .accessibilityIdentifier("messageInput")
                .accessibilityShortLabel("Message input")
                .accessibilityHint("Type your message. Cmd+Enter to send. Escape to clear.")
                .onEscapeKey { 
                    viewModel.inputText = ""
                    AccessibilityHelpers.announceHighPriority("Message cleared")
                }
                .onKeyPress("v", modifiers: [.command, .shift]) {
                    pasteAndSend()
                    return .handled
                }

            Button(action: sendCurrentInput) {
                Image(systemName: "paperplane.fill")
            }
            .buttonStyle(.borderedProminent)
            .disabled(viewModel.inputText.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
            .accessibilityIdentifier("sendButton")
            .accessibilityShortLabel(AccessibleButtonLabels.send)
            .accessibilityValue(viewModel.inputText.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty ? "Disabled – no text" : "Ready")
            .accessibilityHint(AccessibleButtonLabels.sendHint)
            .keyboardShortcut(.return, modifiers: .command)
        }
        .padding(12)
        .accessibilityIdentifier(AccessibilitySectionID.inputSection)
        .accessibilityElement(children: .contain)
        .accessibilityLabel("Message input area")
        .accessibilityHint("Type and send messages. Cmd+1 for chat, Cmd+2 for input, Cmd+3 for controls.")
    }

    private func sendCurrentInput() {
        let trimmedInput = viewModel.inputText.trimmingCharacters(in: .whitespacesAndNewlines)
        guard !trimmedInput.isEmpty else { return }
        
        // Add to message history
        messageHistory.append(trimmedInput)
        messageHistoryIndex = -1
        
        Task {
            await viewModel.sendMessage()
            await MainActor.run {
                isTextFieldFocused = true
                focusTarget = .inputField
            }
        }
    }
    
    private func pasteAndSend() {
        if let pastedText = NSPasteboard.general.string(forType: .string) {
            viewModel.inputText = pastedText
            sendCurrentInput()
            postAccessibilityAnnouncement("Pasted and sent message from clipboard", priority: NSAccessibilityPriorityLevel.high.rawValue)
        } else {
            postAccessibilityAnnouncement("Clipboard is empty", priority: NSAccessibilityPriorityLevel.high.rawValue)
        }
    }
    
    private func newConversation() {
        viewModel.clearConversation()
        messageHistory.removeAll()
        messageHistoryIndex = -1
        viewModel.inputText = ""
        isTextFieldFocused = true
        focusTarget = .inputField
        postAccessibilityAnnouncement("Started a new conversation", priority: NSAccessibilityPriorityLevel.high.rawValue)
    }
    
    private func previousMessage() {
        guard !messageHistory.isEmpty else { 
            postAccessibilityAnnouncement("No message history", priority: NSAccessibilityPriorityLevel.high.rawValue)
            return 
        }
        
        if messageHistoryIndex < messageHistory.count - 1 {
            messageHistoryIndex += 1
            viewModel.inputText = messageHistory[messageHistory.count - 1 - messageHistoryIndex]
            postAccessibilityAnnouncement("Previous message: \(viewModel.inputText)", priority: NSAccessibilityPriorityLevel.high.rawValue)
        }
    }
    
    private func nextMessage() {
        guard messageHistoryIndex > 0 else {
            viewModel.inputText = ""
            messageHistoryIndex = -1
            postAccessibilityAnnouncement("Current message cleared", priority: NSAccessibilityPriorityLevel.high.rawValue)
            return
        }
        
        messageHistoryIndex -= 1
        if messageHistoryIndex >= 0 {
            viewModel.inputText = messageHistory[messageHistory.count - 1 - messageHistoryIndex]
            postAccessibilityAnnouncement("Next message: \(viewModel.inputText)", priority: NSAccessibilityPriorityLevel.high.rawValue)
        } else {
            viewModel.inputText = ""
            postAccessibilityAnnouncement("Current message cleared", priority: NSAccessibilityPriorityLevel.high.rawValue)
        }
    }
    
    private func repeatLastResponse() {
        if let lastMessage = store.conversations.last?.messages.last, lastMessage.role == "assistant" {
            postAccessibilityAnnouncement("Repeating last response", priority: NSAccessibilityPriorityLevel.high.rawValue)
            voiceManager.speak(lastMessage.content)
        } else {
            postAccessibilityAnnouncement("No previous response to repeat", priority: NSAccessibilityPriorityLevel.high.rawValue)
        }
    }

    private var audioLevelDescription: String {
        // WCAG AAA: Extended descriptions for audio levels
        AudioLevelAccessibility.describe(level: speechManager.audioLevel)
    }

    private func openSettings() {
        if !NSApp.sendAction(Selector(("showSettingsWindow:")), to: nil, from: nil) {
            _ = NSApp.sendAction(Selector(("showPreferencesWindow:")), to: nil, from: nil)
        }
    }

    private func postAccessibilityAnnouncement(_ message: String, priority: Int = 50) {
        NSAccessibility.post(
            element: NSApp as Any,
            notification: .announcementRequested,
            userInfo: [
                .announcement: message,
                .priority: priority
            ]
        )
    }
}

// MARK: - Keyboard Shortcuts Help Overlay

struct KeyboardShortcutsHelpOverlay: View {
    @Binding var isPresented: Bool
    
    let shortcuts: [(key: String, action: String, modifiers: String)] = [
        // Navigation
        ("1", "Focus chat area", "Cmd"),
        ("2", "Focus message input", "Cmd"),
        ("3", "Focus controls", "Cmd"),
        
        // Message handling
        ("Enter", "Send message", "Cmd"),
        ("V", "Paste and send", "Cmd+Shift"),
        ("Up Arrow", "Previous message in history", "Cmd"),
        ("Down Arrow", "Next message in history", "Cmd"),
        
        // Conversation
        ("N", "Start new conversation", "Cmd"),
        ("K", "Clear conversation", "Cmd"),
        ("R", "Repeat last response", "Cmd"),
        
        // Audio
        ("L / M", "Toggle microphone", "Cmd"),
        (".", "Stop speaking", "Cmd"),
        
        // Settings & Help
        (",", "Open settings", "Cmd"),
        ("? / /", "Show this help", "Cmd"),
        
        // Input editing
        ("Escape", "Clear input text", ""),
    ]
    
    var body: some View {
        ZStack {
            Color.black.opacity(0.4)
                .ignoresSafeArea()
                .onTapGesture {
                    isPresented = false
                }
            
            VStack(spacing: 16) {
                HStack {
                    Text("Keyboard Shortcuts")
                        .font(.headline)
                        .accessibilityAddTraits(.isHeader)
                    Spacer()
                    Button(action: { isPresented = false }) {
                        Image(systemName: "xmark.circle.fill")
                            .foregroundColor(.secondary)
                    }
                    .buttonStyle(.plain)
                    .accessibilityLabel("Close help")
                    .accessibilityHint("Press Escape or click to close")
                }
                .padding(.horizontal)
                .padding(.top)
                
                ScrollView {
                    VStack(alignment: .leading, spacing: 12) {
                        ForEach(groupedShortcuts(), id: \.0) { group, items in
                            VStack(alignment: .leading, spacing: 8) {
                                Text(group)
                                    .font(.caption)
                                    .fontWeight(.semibold)
                                    .foregroundColor(.secondary)
                                    .textCase(.uppercase)
                                    .accessibilityAddTraits(.isHeader)
                                
                                VStack(alignment: .leading, spacing: 6) {
                                    ForEach(items, id: \.key) { item in
                                        HStack {
                                            VStack(alignment: .leading, spacing: 2) {
                                                Text(item.action)
                                                    .font(.body)
                                                Text(formatModifiers(item.modifiers) + item.key)
                                                    .font(.caption)
                                                    .foregroundColor(.secondary)
                                                    .monospaced()
                                            }
                                            Spacer()
                                        }
                                        .padding(8)
                                        .background(Color.gray.opacity(0.1))
                                        .cornerRadius(6)
                                        .accessibilityElement(children: .combine)
                                        .accessibilityLabel(item.action)
                                        .accessibilityValue("\(formatModifiers(item.modifiers))\(item.key)")
                                    }
                                }
                            }
                            .padding(.horizontal)
                            
                            if group != groupedShortcuts().last?.0 {
                                Divider()
                                    .padding(.horizontal)
                            }
                        }
                    }
                    .padding(.vertical)
                }
                
                HStack(spacing: 12) {
                    Text("💡 Tip: Press Escape to clear your message quickly")
                        .font(.caption)
                        .foregroundColor(.secondary)
                    Spacer()
                }
                .padding(.horizontal)
                .padding(.bottom)
            }
            .frame(maxWidth: 500)
            .background(Color(nsColor: .controlBackgroundColor))
            .cornerRadius(12)
            .shadow(radius: 8)
            .padding()
            .accessibilityIdentifier("keyboardShortcutsHelp")
        }
        .onKeyPress(.escape) {
            isPresented = false
            return .handled
        }
    }
    
    private func groupedShortcuts() -> [(String, [(key: String, action: String, modifiers: String)])] {
        let groups: [String: [(key: String, action: String, modifiers: String)]] = [
            "Navigation": shortcuts.filter { ["1", "2", "3"].contains($0.key) },
            "Message Handling": shortcuts.filter { ["Enter", "V", "Up Arrow", "Down Arrow"].contains($0.key) },
            "Conversation": shortcuts.filter { ["N", "K", "R"].contains($0.key) },
            "Audio": shortcuts.filter { ["L / M", ".", "Escape"].contains($0.key) },
            "Settings & Help": shortcuts.filter { [",", "? / /"].contains($0.key) },
        ]
        
        return [
            ("Navigation", groups["Navigation"] ?? []),
            ("Message Handling", groups["Message Handling"] ?? []),
            ("Conversation", groups["Conversation"] ?? []),
            ("Audio", groups["Audio"] ?? []),
            ("Settings & Help", groups["Settings & Help"] ?? []),
        ]
    }
    
    private func formatModifiers(_ modifiers: String) -> String {
        guard !modifiers.isEmpty else { return "" }
        return modifiers + " + "
    }
}

// MARK: - Keyboard helpers

struct KeyEventHandlerView: NSViewRepresentable {
    let onSpaceDown: () -> Void
    let onSpaceUp: () -> Void

    func makeNSView(context: Context) -> KeyEventNSView {
        let view = KeyEventNSView()
        view.onSpaceDown = onSpaceDown
        view.onSpaceUp = onSpaceUp
        return view
    }

    func updateNSView(_ nsView: KeyEventNSView, context: Context) {
        nsView.onSpaceDown = onSpaceDown
        nsView.onSpaceUp = onSpaceUp
    }
}

class KeyEventNSView: NSView {
    var onSpaceDown: (() -> Void)?
    var onSpaceUp: (() -> Void)?
    private var spaceIsDown = false

    override var acceptsFirstResponder: Bool { true }

    override func keyDown(with event: NSEvent) {
        if event.keyCode == 49 && !event.isARepeat && !spaceIsDown {
            spaceIsDown = true
            onSpaceDown?()
        } else {
            super.keyDown(with: event)
        }
    }

    override func keyUp(with event: NSEvent) {
        if event.keyCode == 49 {
            spaceIsDown = false
            onSpaceUp?()
        } else {
            super.keyUp(with: event)
        }
    }
}

// MARK: - onEscapeKey modifier

extension View {
    @ViewBuilder
    func onEscapeKey(action: @escaping () -> Void) -> some View {
        if #available(macOS 14.0, iOS 17.0, *) {
            self.onKeyPress(.escape) { action(); return .handled }
        } else {
            self
        }
    }
}
