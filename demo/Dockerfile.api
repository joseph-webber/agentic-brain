FROM python:3.11-slim

ARG AGENTIC_BRAIN_VERSION=local

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    AGENTIC_BRAIN_VERSION=${AGENTIC_BRAIN_VERSION}

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY src ./src

# Configure pip for corporate proxies (trusted hosts for Windows/SSL issues)
RUN pip config set global.trusted-host "pypi.org pypi.python.org files.pythonhosted.org"

RUN python -m pip install --upgrade pip setuptools wheel \
        --trusted-host pypi.org --trusted-host pypi.python.org --trusted-host files.pythonhosted.org && \
    python -m pip install ".[api]" \
        --trusted-host pypi.org --trusted-host pypi.python.org --trusted-host files.pythonhosted.org

RUN useradd -m -u 1000 -s /bin/bash agentic && \
    mkdir -p /app/data && \
    chown -R agentic:agentic /app

USER agentic

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=5 \
    CMD curl -fsS http://localhost:8000/health || exit 1

CMD ["agentic-brain", "serve", "--host", "0.0.0.0", "--port", "8000"]
