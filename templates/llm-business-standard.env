# =============================================================================
# Agentic Brain - LLM Configuration Template: BUSINESS STANDARD
# =============================================================================
# Last verified: March 2026
# Template: Business Standard - Quality + Cost Balance
# Best for: SMBs, consultants, agencies, professional use
# =============================================================================

# === LOCAL FALLBACK ===
OLLAMA_HOST=http://localhost:11434

# === FREE PROVIDERS (use first) ===

# Groq - fast and free
GROQ_API_KEY=gsk_your_key_here

# Google Gemini - free tier
GOOGLE_API_KEY=your_key_here

# === PAID PROVIDERS (quality when needed) ===

# OpenAI - excellent coding and general use
# Sign up: https://platform.openai.com
OPENAI_API_KEY=sk-your_key_here

# Anthropic Claude - best reasoning and analysis
# Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# === BUSINESS SETTINGS ===

# Budget model default (good quality, low cost)
DEFAULT_MODEL=OP2

# Smart fallback: budget first, quality when needed
FALLBACK_CHAIN=GR,L2,OP2,CL2,OP,CL

# Allow cloud
ALLOW_CLOUD_FALLBACK=true

# Business continuity
OFFLINE_MODE=false

# Standard timeout
REQUEST_TIMEOUT=30

# =============================================================================
# Template notes:
# - Typical cost: $20-50 AUD/month
# - Uses FREE first, paid only when needed
# - GPT-4o-mini and Haiku are great value
# - Claude for complex analysis, OpenAI for coding
# - Good balance of quality and cost
# =============================================================================
