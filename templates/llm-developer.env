# =============================================================================
# Agentic Brain - LLM Configuration Template: DEVELOPER
# =============================================================================
# Last verified: March 2026
# Template: Developer - Optimized for coding tasks
# Best for: Software developers, coding assistants, code review
# =============================================================================

# === LOCAL MODELS ===
OLLAMA_HOST=http://localhost:11434

# === DEVELOPER-OPTIMIZED PROVIDERS ===

# Groq - fast iterations
GROQ_API_KEY=gsk_your_key_here

# Google Gemini - long file context
GOOGLE_API_KEY=your_key_here

# OpenAI - excellent at code
OPENAI_API_KEY=sk-your_key_here

# Claude - great at reasoning about code
ANTHROPIC_API_KEY=sk-ant-your_key_here

# === CODING SETTINGS ===

# GPT-4o excels at coding tasks
DEFAULT_MODEL=OP

# Developer fallback: coding-optimized models
FALLBACK_CHAIN=OP,L2,CL,GR,OP2

# Allow cloud for quality
ALLOW_CLOUD_FALLBACK=true

# Can work offline with local models
OFFLINE_MODE=false

# Longer timeout for complex code generation
REQUEST_TIMEOUT=60

# === CODE-SPECIFIC OPTIONS ===
# Enable code formatting in responses
CODE_HIGHLIGHTING=true

# Include line numbers
CODE_LINE_NUMBERS=true

# =============================================================================
# Template notes:
# - GPT-4o and Claude are best for code
# - Local L2 (llama3.1:8b) surprisingly good for quick tasks
# - Groq for fast iterations
# - Gemini for reviewing large codebases (1M context)
# - Typical cost: $10-30 AUD/month
# =============================================================================
