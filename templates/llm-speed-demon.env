# =============================================================================
# Agentic Brain - LLM Configuration Template: SPEED DEMON
# =============================================================================
# Last verified: March 2026
# Template: Speed Demon - Fastest possible responses
# Best for: Real-time apps, high-volume processing, latency-sensitive
# =============================================================================

# === LOCAL FALLBACK ===
OLLAMA_HOST=http://localhost:11434

# === SPEED-OPTIMIZED PROVIDERS ===

# Groq - THE fastest LLM inference (300-500 tokens/sec!)
# This is your primary - nothing beats Groq speed
GROQ_API_KEY=gsk_your_key_here

# Google Gemini Flash - very fast
GOOGLE_API_KEY=your_key_here

# === SPEED SETTINGS ===

# Groq first - fastest inference on the planet
DEFAULT_MODEL=GR

# Speed-optimized fallback chain
FALLBACK_CHAIN=GR,GR2,L1,GO

# Allow cloud for speed
ALLOW_CLOUD_FALLBACK=true

# Need internet for cloud speed
OFFLINE_MODE=false

# Lower timeout for faster failover
REQUEST_TIMEOUT=10

# =============================================================================
# Template notes:
# - Groq: 300-500 tokens/second (10x faster than OpenAI!)
# - Sub-second response times typical
# - FREE tier: 30 req/min, 6K tok/min
# - Falls back to local L1 if rate limited
# - Perfect for real-time chat, live demos, time-critical apps
# =============================================================================
