# =============================================================================
# Agentic Brain - LLM Configuration Template: BUDGET ZERO
# =============================================================================
# Last verified: March 2026
# Template: Budget Zero - 100% FREE, no credit card needed
# Best for: Students, hobbyists, learners, startups
# =============================================================================

# === FREE LOCAL (Ollama) ===
OLLAMA_HOST=http://localhost:11434

# === FREE CLOUD PROVIDERS ===

# Groq - Super fast inference, 30 req/min free
# Sign up: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Google Gemini - 1M token context, 15 req/min free
# Sign up: https://aistudio.google.com
GOOGLE_API_KEY=your_key_here

# === DEFAULT SETTINGS ===

# Start with local (zero cost)
DEFAULT_MODEL=L1

# Fallback: local first, then free cloud
FALLBACK_CHAIN=L1,L2,GR,GR2,GO

# Allow cloud but stay on free tiers
ALLOW_CLOUD_FALLBACK=true

# Can work offline too
OFFLINE_MODE=false

# =============================================================================
# Template notes:
# - $0/month forever - no credit card needed
# - Gets 99% of what paid models offer
# - Groq is insanely fast (300+ tokens/sec)
# - Gemini has 1M token context (huge documents!)
# - All providers have generous free tiers
# =============================================================================
