# =============================================================================
# Agentic Brain - LLM Configuration Template: PRIVACY FIRST
# =============================================================================
# Last verified: March 2026
# Template: Privacy First - Maximum data protection
# Best for: Lawyers, doctors, accountants, regulated industries
# =============================================================================

# === LOCAL MODELS ONLY (Ollama) ===
# Data NEVER leaves your machine. No cloud. No exceptions.

OLLAMA_HOST=http://localhost:11434

# Primary model - quality reasoning (requires 8GB+ RAM)
DEFAULT_MODEL=L2

# Fallback chain - all local, all private
FALLBACK_CHAIN=L2,L1,L3

# === PRIVACY SETTINGS ===
# These are critical for maximum privacy

# Never fall back to cloud even if local fails
ALLOW_CLOUD_FALLBACK=false

# Work without internet
OFFLINE_MODE=true

# Don't log prompts (extra privacy)
LOG_PROMPTS=false

# === NO CLOUD PROVIDERS ===
# Intentionally empty - we don't send data anywhere

# GROQ_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# =============================================================================
# Template notes:
# - All processing happens locally on YOUR computer
# - Works completely offline (planes, outback, anywhere)
# - Compliant with Privacy Act (AU), HIPAA (US), GDPR (EU)
# - Requires 8GB+ RAM for L2 model
# - No monthly costs ever
# =============================================================================
