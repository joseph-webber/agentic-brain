# =============================================================================
# Agentic Brain - LLM Configuration Template: AUSSIE DEFAULT
# =============================================================================
# Last verified: March 2026
# Template: Aussie Default - Joseph's Recommended Balanced Setup
# Best for: Most Australians - balanced, sensible, no dramas
# =============================================================================

# === LOCAL FOUNDATION ===
# Always have local as backup - works even when NBN is playing up
OLLAMA_HOST=http://localhost:11434

# === FREE CLOUD (Use These First) ===

# Groq - bloody fast, mate
# Sign up: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Google Gemini - massive context, she'll be right
# Sign up: https://aistudio.google.com
GOOGLE_API_KEY=your_key_here

# === PAID CLOUD (Quality When Needed) ===

# Anthropic Claude - best for reasoning
# Note: +10% GST for Aussies
ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI - optional, good for coding
# Note: +10% GST for Aussies
# OPENAI_API_KEY=sk-your_key_here

# === AUSSIE-SENSIBLE SETTINGS ===

# Start local (no cost, no dramas)
DEFAULT_MODEL=L2

# Smart fallback: local → free cloud → paid (as last resort)
FALLBACK_CHAIN=L2,L1,GR,GO,CL2,CL

# Cloud is fine when needed
ALLOW_CLOUD_FALLBACK=true

# Can work offline too (good for outback trips!)
OFFLINE_MODE=false

# Standard timeout
REQUEST_TIMEOUT=30

# =============================================================================
# Template notes:
# - Typical cost: $0-20 AUD/month (mostly free!)
# - Local first = fast + private + free
# - Groq when you need speed (it's FREE!)
# - Claude when you need smarts (small cost)
# - Works offline too - no worries if NBN drops
# - GST (10%) applies to paid providers for Aussie customers
# =============================================================================
