// Minimal Persona - Bare minimum chatbot
// Generated by Agentic Brain Installer

application AgenticBrain {
  name "Simple Chat"
  persona minimal
}

llm Primary {
  provider auto
  model "llama3.2:3b"
  temperature 0.7
  maxTokens 2048
}

modes {
  default free
  routing simple  // No smart routing
}

security {
  level standard
  rateLimit 100
  requireAuth false
}
