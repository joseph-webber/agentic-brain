  "components": {
    "schemas": {
      "ChatRequest": {
        "properties": {
          "message": {
            "type": "string",
            "maxLength": 32000,
            "minLength": 1,
            "title": "Message",
            "description": "The user's message"
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 64
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id",
            "description": "Session ID for conversation tracking"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 64
              },
              {
                "type": "null"
              }
            ],
            "title": "User Id",
            "description": "User ID for multi-user support"
          },
          "metadata": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Metadata",
            "description": "Optional metadata for extended request information"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatRequest",
        "description": "Request model for chat endpoint.\n\nAttributes:\n    message: The user's message/query\n    session_id: Optional session identifier for conversation tracking\n    user_id: Optional user identifier for multi-user support\n    metadata: Optional metadata dictionary for extended request information"
      },
      "ChatResponse": {
        "properties": {
          "response": {
            "type": "string",
            "title": "Response",
            "description": "The chatbot's response"
          },
          "session_id": {
            "type": "string",
            "title": "Session Id",
            "description": "Session ID for this conversation"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp",
            "description": "Timestamp of response generation"
          },
          "message_id": {
            "type": "string",
            "title": "Message Id",
            "description": "Unique message identifier"
          }
        },
        "type": "object",
        "required": [
          "response",
          "session_id",
          "message_id"
        ],
        "title": "ChatResponse",
        "description": "Response model for chat endpoint.\n\nAttributes:\n    response: The chatbot's response message\n    session_id: The session ID for this conversation\n    timestamp: When the response was generated\n    message_id: Unique identifier for this message exchange"
      },
      "ConfigUpdate": {
        "properties": {
          "key": {
            "type": "string",
            "title": "Key"
          },
          "value": {
            "title": "Value"
          }
        },
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "title": "ConfigUpdate",
        "description": "Configuration update model."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthStatus": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "neo4j_connected": {
            "type": "boolean",
            "title": "Neo4J Connected"
          },
          "llm_provider_available": {
            "type": "boolean",
            "title": "Llm Provider Available"
          },
          "memory_ok": {
            "type": "boolean",
            "title": "Memory Ok"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "status",
          "neo4j_connected",
          "llm_provider_available",
          "memory_ok",
          "timestamp"
        ],
        "title": "HealthStatus",
        "description": "Health status model."
      },
      "SessionInfo": {
        "properties": {
          "id": {
            "type": "string",
            "maxLength": 64,
            "title": "Id",
            "description": "Session ID"
          },
          "message_count": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Message Count",
            "description": "Number of messages in session",
            "default": 0
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At",
            "description": "Session creation timestamp"
          },
          "last_accessed": {
            "type": "string",
            "format": "date-time",
            "title": "Last Accessed",
            "description": "Last access timestamp"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string",
                "maxLength": 64
              },
              {
                "type": "null"
              }
