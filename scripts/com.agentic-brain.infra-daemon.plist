<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.agentic-brain.infra-daemon</string>
	
	<key>ProgramArguments</key>
	<array>
		<string>/Users/joe/brain/agentic-brain/scripts/infra-daemon.sh</string>
		<string>start</string>
	</array>
	
	<key>RunAtLoad</key>
	<true/>
	
	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	
	<key>StandardOutPath</key>
	<string>/Users/joe/brain/agentic-brain/logs/infra-daemon.stdout.log</string>
	
	<key>StandardErrorPath</key>
	<string>/Users/joe/brain/agentic-brain/logs/infra-daemon.stderr.log</string>
	
	<key>StartInterval</key>
	<integer>300</integer>
	
	<key>UserName</key>
	<string>joe</string>
</dict>
</plist>
