# Environment configuration example
# Copy to .env and fill in your actual values

# Neo4j Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# LLM Providers (set API key for your chosen provider)
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENROUTER_API_KEY=sk-or-your-key-here

# Ollama (local, no API key needed)
OLLAMA_API_BASE=http://localhost:11434

# Valid values:
# DEFAULT_LLM_PROVIDER: ollama, openai, anthropic, openrouter
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
DASHBOARD_ENABLED=true

# Logging
LOG_LEVEL=INFO

# Firebase Transport (optional)
# Get credentials from Firebase Console > Project Settings > Service Accounts
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_CREDENTIALS=/path/to/firebase-credentials.json
