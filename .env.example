#
# Environment Configuration Example
# Copy to .env and fill in your actual values
# 
# SECTIONS:
#   1. LLM Providers (choose at least one)
#   2. LLM Configuration (required)
#   3. Neo4j Memory & Persistence (optional)
#   4. Redis Session Storage (optional)
#   5. API Server & Dashboard (required for API)
#   6. Authentication & Security (optional)
#   7. Firebase Integration (optional)
#   8. Vector Databases (optional)
#   9. Directory Services (optional)
#  10. SSL/TLS Configuration (optional)
#  11. Text-to-Speech (optional)

################################################################################
# SECTION 1: LLM PROVIDERS
################################################################################
# ⭐ Start with DEFAULT_LLM_PROVIDER at the end of this section
# Pick at least ONE provider - most need setup steps
#
# RECOMMENDED START:
#   - Ollama (free, local, private) - best for development
#   - OR Groq (free cloud, fast)
#   - OR Google Gemini (free cloud, generous limits)

# ===== LOCAL / PRIVACY-FIRST (FREE) =====
# [OPTIONAL] Ollama - Local LLM (100% private, offline-capable, free)
#   Setup: https://ollama.ai → ollama pull llama3.2 && ollama serve
#   Speed: ~1-5s per response (depends on your hardware)
#   Cost: FREE (runs on your machine)
#   Use when: Privacy matters, offline capability needed, learning/development
OLLAMA_BASE_URL=http://localhost:11434

# ===== FREE CLOUD PROVIDERS =====

# [OPTIONAL] Groq - Fast inference cloud (FREE, 30 req/min)
#   Setup: https://console.groq.com/keys
#   Speed: ~100ms (fastest available!)
#   Cost: FREE tier (30 requests/minute)
#   Use when: Need speed, quick testing, real-time chat
GROQ_API_KEY=groq_placeholder_key_xxx

# [OPTIONAL] Google Gemini (via AI Studio) - FREE cloud access (1M tokens/day)
#   Setup: https://aistudio.google.com/apikey
#   Speed: ~1-2s per response
#   Cost: FREE (1,000,000 tokens per day - very generous!)
#   Use when: Experimenting, light production use
GOOGLE_API_KEY=google_placeholder_key_xxx
GEMINI_MODEL=gemini-2.0-flash

# [OPTIONAL] OpenRouter - Gateway to 200+ models (FREE tier: 50 calls/day)
#   Setup: https://openrouter.ai/keys
#   Speed: ~1-3s (varies by model selection)
#   Cost: FREE tier (50 calls/day), then pay-as-you-go
#   Use when: Testing different models, need model variety
OPENROUTER_API_KEY=openrouter_placeholder_key_xxx
OPENROUTER_GEMINI_MODEL=google/gemini-2.0-flash-001
OPENROUTER_GROK_MODEL=x-ai/grok-2

# [OPTIONAL] Together.ai - Model hub with free credits ($25 startup)
#   Setup: https://www.together.ai/settings/api-keys
#   Speed: ~1-2s per response
#   Cost: FREE ($25 credit to start)
#   Use when: Cost-conscious experimentation with open-source models
TOGETHER_API_KEY=together_placeholder_key_xxx

# [OPTIONAL] Hugging Face - 100K+ open-source models (FREE tier available)
#   Setup: https://huggingface.co/settings/tokens (create User token)
#   Speed: ~2-5s (varies by model/server load)
#   Cost: FREE tier (rate limited, inference API has paid options)
#   Use when: Accessing diverse open-source models
HUGGINGFACE_API_KEY=huggingface_placeholder_token_xxx

# [OPTIONAL] Mistral - Strong coding & reasoning (FREE: ~25K tokens/day)
#   Setup: https://console.mistral.ai (requires phone verification)
#   Speed: ~1-2s per response
#   Cost: FREE tier (~25K tokens/day), then paid
#   Use when: Code generation, technical reasoning
MISTRAL_API_KEY=mistral_placeholder_key_xxx

# [OPTIONAL] Cohere - Best for search & embeddings (FREE trial available)
#   Setup: https://dashboard.cohere.com
#   Speed: ~1-2s per response
#   Cost: FREE trial tier
#   Use when: Semantic search, embeddings, RAG applications
COHERE_API_KEY=cohere_placeholder_key_xxx

# [OPTIONAL] Cloudflare Workers AI - Serverless edge AI (FREE tier)
#   Setup: https://dash.cloudflare.com → Workers AI
#   Speed: ~500ms (edge-deployed)
#   Cost: FREE tier included with Cloudflare account
#   Use when: Serverless edge deployment, low latency
CLOUDFLARE_ACCOUNT_ID=cloudflare_account_id_xxx
CLOUDFLARE_API_TOKEN=cloudflare_api_token_xxx

# ===== PAID PREMIUM PROVIDERS =====

# [OPTIONAL] OpenAI - ChatGPT API (REQUIRES PAYMENT)
#   Setup: https://platform.openai.com/api-keys
#   Speed: ~1-2s per response
#   Cost: ~$0.01-0.30 per request (pay-as-you-go, very cheap!)
#   Use when: Production, highest quality, best reasoning
OPENAI_API_KEY=openai_placeholder_key_xxx

# [OPTIONAL] Azure OpenAI - Enterprise OpenAI deployment
#   Setup: Azure Portal → Azure OpenAI → Create Deployment
#   Speed: ~1-2s per response
#   Cost: Same as OpenAI (pay-as-you-go via Azure)
#   Use when: Enterprise deployment, integration with Azure services
#   Note: Model name maps to your deployment name
AZURE_OPENAI_API_KEY=azure_openai_placeholder_key_xxx
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# [OPTIONAL] Anthropic Claude - Advanced reasoning (REQUIRES PAYMENT)
#   Setup: https://console.anthropic.com/
#   Speed: ~2-3s per response
#   Cost: ~$0.003-0.030 per request (pay-as-you-go)
#   Use when: Production, nuanced reasoning, long context windows
ANTHROPIC_API_KEY=anthropic_placeholder_key_xxx

# [OPTIONAL] xAI Grok - Fast reasoning engine (REQUIRES PAYMENT)
#   Setup: https://console.x.ai → Create API key
#   Speed: ~1-2s per response
#   Cost: Pay-as-you-go (~$0.005-0.30/request) - NO FREE TIER
#   ⚠️ WARNING: You MUST add payment method to use this
#   Use when: Fast reasoning, real-time capabilities, power user features
XAI_API_KEY=xai_placeholder_key_xxx
GROK_MODEL=grok-2

# ===== LLM CONFIGURATION (REQUIRED) =====
# Which provider to use when not specified in code
# Pick ONE from: ollama, openai, anthropic, openrouter, groq, google, cohere, mistral, together, huggingface, cloudflare, xai, azure_openai
# DEFAULT: ollama (free, works immediately - just run `ollama serve`)
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2

################################################################################
# SECTION 2: NEO4J MEMORY & PERSISTENCE (OPTIONAL)
################################################################################
# Neo4j adds conversation history, memory, and semantic search
# ⚠️ Chat works perfectly WITHOUT Neo4j - this section is optional
#
# Quick setup: docker run -d -p 7474:7474 -p 7687:7687 neo4j
#
# [OPTIONAL] Enable Neo4j for memory features
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=placeholder_password_change_this_xxx
NEO4J_HTTP_URL=http://localhost:7474/db/neo4j/

################################################################################
# SECTION 3: REDIS SESSION STORAGE (OPTIONAL)
################################################################################
# Redis stores user sessions across server restarts/load balancers
# [OPTIONAL] Only needed for production or multi-instance deployments
#
# SESSION_BACKEND: Choose storage backend
#   - memory (default) = sessions lost on restart, fine for development
#   - redis = persistent sessions, required for production
SESSION_BACKEND=memory

# [OPTIONAL] Redis connection (only used if SESSION_BACKEND=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=placeholder_redis_password_xxx
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# Session configuration
SESSION_MAX_AGE=3600

################################################################################
# SECTION 4: API SERVER & DASHBOARD (REQUIRED FOR API)
################################################################################
# Configure the API server (if running as a service)

# API Server binding
# API_HOST: Which network interface to listen on
#   - 0.0.0.0 = listen on all interfaces (for Docker, multi-host)
#   - 127.0.0.1 = localhost only (safe for development)
API_HOST=0.0.0.0
API_PORT=8000

# Web dashboard
DASHBOARD_ENABLED=true

# Logging configuration
LOG_LEVEL=INFO

# Audit logging (track all API calls for compliance)
AUDIT_ENABLED=true
AUDIT_LOG_FILE=/var/log/agentic-brain/audit.log
AUDIT_LOG_LEVEL=INFO

################################################################################
# SECTION 5: AUTHENTICATION & SECURITY (OPTIONAL)
################################################################################
# Control who can access the API and dashboard

# [OPTIONAL] Enable API authentication
# Set to true to require authentication for all endpoints
AUTH_ENABLED=false

# [OPTIONAL] Static API keys (comma-separated list)
# Only used if AUTH_ENABLED=true
API_KEYS=placeholder_api_key_1,placeholder_api_key_2,placeholder_api_key_3

# [OPTIONAL] JWT authentication (if using JWT tokens)
# JWT_SECRET must be changed in production!
JWT_SECRET=placeholder_super_secret_jwt_key_change_in_production_xxx
JWT_ALGORITHM=HS256

# [OPTIONAL] CORS security (control which domains can access the API)
# Comma-separated list of allowed origins
# Examples: http://localhost:3000, https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# [OPTIONAL] Content Security Policy (CSP)
# CSP_STRICT=false allows inline CSS/scripts (easier for development)
# CSP_STRICT=true requires external resources (better security)
CSP_STRICT=false

################################################################################
# SECTION 6: FIREBASE INTEGRATION (OPTIONAL)
################################################################################
# Real-time database, authentication, and storage via Google Firebase
# [OPTIONAL] Get credentials from Firebase Console > Project Settings > Service Accounts

FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
FIREBASE_CREDENTIALS=/path/to/firebase-credentials.json

# Firebase Emulator hosts (for local development with Firebase CLI)
FIREBASE_AUTH_HOST=localhost
FIREBASE_FIRESTORE_HOST=localhost
FIREBASE_DATABASE_HOST=localhost
FIREBASE_STORAGE_HOST=localhost
FIREBASE_FUNCTIONS_HOST=localhost
FIREBASE_PUBSUB_HOST=localhost

################################################################################
# SECTION 7: VECTOR DATABASES (OPTIONAL)
################################################################################
# For semantic search and similarity matching
# [OPTIONAL] Choose ONE or skip if not using semantic search

# Qdrant (popular, feature-rich)
QDRANT_URL=http://localhost:6333

# Weaviate (alternative vector DB)
WEAVIATE_URL=http://localhost:8080

################################################################################
# SECTION 8: DIRECTORY SERVICES (OPTIONAL)
################################################################################
# Integration with corporate directory systems for SSO

# [OPTIONAL] LDAP authentication
LDAP_SERVER=ldap://localhost
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=placeholder_ldap_password_xxx

# [OPTIONAL] SAML SSO (Security Assertion Markup Language)
SAML_ACS_URL=http://localhost:8000/auth/saml/acs

################################################################################
# SECTION 9: SSL/TLS CONFIGURATION (OPTIONAL)
################################################################################
# Enable HTTPS for secure connections
# [OPTIONAL] For production only - development uses HTTP

# Enable SSL/HTTPS
# true = require HTTPS (all connections must be encrypted)
# false = allow HTTP (development default)
SSL_ENABLED=false

# [OPTIONAL] SSL certificate paths (required if SSL_ENABLED=true)
# For Let's Encrypt:  certbot certonly --standalone -d yourdomain.com
# For self-signed:    openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes
SSL_CERT_FILE=/path/to/certificate.pem
SSL_KEY_FILE=/path/to/private-key.pem

# [OPTIONAL] SSL verification
# true = verify SSL certificates (production)
# false = skip verification (development with self-signed certs)
SSL_VERIFY=true

# [OPTIONAL] Corporate SSL certificates
# For environments using internal CAs or corporate proxies
# REQUESTS_CA_BUNDLE=/path/to/corporate-ca-bundle.crt
# SSL_CERT_DIR=/etc/ssl/certs

################################################################################
# SECTION 10: TEXT-TO-SPEECH (OPTIONAL)
################################################################################
# Cartesia - Low-latency cloud TTS (40ms to first audio byte)
# [OPTIONAL] Get API key from https://play.cartesia.ai/

CARTESIA_API_KEY=placeholder_cartesia_api_key_xxx
CARTESIA_VOICE_ID=placeholder_voice_id_xxx
