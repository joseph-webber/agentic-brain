# ═══════════════════════════════════════════════════════════════════════════
# AGENTIC BRAIN - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your API keys
# NEVER commit .env to git (it's in .gitignore)
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# LLM PROVIDERS - Smart Routing Cascade (fastest to slowest)
# ═══════════════════════════════════════════════════════════════════════════

# Priority 1: GROQ (500 tokens/sec - ULTRA FAST, FREE)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Priority 2: LOCAL OLLAMA (always available, no key needed)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Then run: ollama pull llama3.2:3b && ollama serve
OLLAMA_HOST=http://localhost:11434

# Priority 3: OPENAI (GPT-4, GPT-4o)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Priority 4: ANTHROPIC CLAUDE (Claude 3.5/4)
# Get key: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-your_claude_key_here
ANTHROPIC_API_KEY=${CLAUDE_API_KEY}

# Priority 5: GOOGLE GEMINI
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-your_gemini_key_here
GOOGLE_API_KEY=${GEMINI_API_KEY}

# Priority 6: XAI GROK
# Get key: https://console.x.ai/
XAI_API_KEY=xai-your_grok_key_here
GROK_API_KEY=${XAI_API_KEY}

# ═══════════════════════════════════════════════════════════════════════════
# VOICE / TTS
# ═══════════════════════════════════════════════════════════════════════════

# Cartesia (ultra-low latency TTS)
# Get key: https://play.cartesia.ai/
CARTESIA_API_KEY=sk_car_your_cartesia_key_here

# ═══════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE (Docker Compose defaults)
# ═══════════════════════════════════════════════════════════════════════════

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=Brain2026

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=BrainRedis2026

# Redpanda/Kafka Event Bus
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ═══════════════════════════════════════════════════════════════════════════
# SMART ROUTING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Enable smart LLM routing (highly recommended)
LLM_ROUTING_ENABLED=true

# Default provider for quick queries
LLM_ROUTING_DEFAULT=groq

# Fallback chain (tried in order if default fails)
LLM_ROUTING_FALLBACK=ollama,openai,claude,gemini,grok

# Response caching
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL: WORK INTEGRATIONS
# ═══════════════════════════════════════════════════════════════════════════

# JIRA
# JIRA_URL=https://your-company.atlassian.net
# JIRA_EMAIL=your@email.com
# JIRA_API_TOKEN=your_jira_token

# GitHub
# GITHUB_TOKEN=ghp_your_github_token

# Bitbucket
# BITBUCKET_USERNAME=your_username
# BITBUCKET_APP_PASSWORD=your_app_password
