# Environment configuration example
# Copy to .env and fill in your actual values

# =============================================================
# ⭐ LLM PROVIDERS (pick at least ONE!)
# =============================================================

# === QUICK START (2 min setup) ===

# Groq (⭐ RECOMMENDED - fastest, free)
# Setup: https://console.groq.com
# Speed: ~100ms responses (fastest!)
# Free tier: 30 requests/minute
# Best for: Quick testing, real-time chat
GROQ_API_KEY=

# === PRIVACY-FIRST (run locally, no cloud) ===

# Ollama (free, local, 100% private - RECOMMENDED FOR PRIVACY)
# Setup: Download from https://ollama.ai
# Speed: ~1-5s (depends on your hardware)
# Free: Yes, runs on your computer
# Best for: Private data, offline, learning
# To start: ollama pull llama3.2 && ollama serve
OLLAMA_BASE_URL=http://localhost:11434

# === FREE CLOUD PROVIDERS ===

# Google AI Studio (free Gemini with 1M tokens/day)
# Setup: https://aistudio.google.com/apikey
# Speed: ~1-2s responses
# Free tier: 1,000,000 tokens per day (very generous!)
# Best for: Experimentation, light use
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# HuggingFace (access to 100K+ open models)
# Setup: https://huggingface.co/settings/tokens
# Speed: ~2-5s (varies by model)
# Free tier: Rate limited, but very flexible
# Best for: Running open-source models
HUGGINGFACE_API_KEY=

# OpenRouter (200+ models with free tier)
# Setup: https://openrouter.ai/keys
# Speed: ~1-3s (varies by model)
# Free tier: 50 calls/day (then you can add credits)
# Best for: Model comparison, accessing multiple providers
OPENROUTER_API_KEY=
OPENROUTER_GEMINI_MODEL=google/gemini-2.0-flash-001
OPENROUTER_GROK_MODEL=x-ai/grok-2

# Together.ai (free $25 credit)
# Setup: https://www.together.ai
# Speed: ~1-2s responses
# Free tier: $25 credit (great for trying out)
# Best for: Cost-effective experimentation
TOGETHER_API_KEY=

# Mistral (great for coding tasks)
# Setup: https://console.mistral.ai (requires phone verification)
# Speed: ~1-2s responses
# Free tier: ~25K tokens/day (generous for coding)
# Best for: Code generation and technical tasks
MISTRAL_API_KEY=

# Cohere (best for search and RAG)
# Setup: https://dashboard.cohere.com
# Speed: ~1-2s responses
# Free tier: Trial key with limited usage
# Best for: Semantic search, embeddings, RAG applications
COHERE_API_KEY=

# Cloudflare Workers AI (free tier, serverless edge)
# Setup: https://dash.cloudflare.com (AI section)
# Speed: ~500ms (edge deployment)
# Free tier: Generous with request limits
# Best for: Edge deployment, serverless
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# === PAID PREMIUM PROVIDERS ===

# OpenAI (ChatGPT API - best quality)
# Setup: https://platform.openai.com/api-keys
# Speed: ~1-2s responses
# Cost: ~$0.01-0.30 per request (very cheap!)
# Best for: Production, highest quality reasoning
OPENAI_API_KEY=

# Azure OpenAI (Enterprise deployments)
# Setup: Azure Portal > Azure OpenAI > Deployments
# Note: Model name maps to deployment name
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Anthropic Claude (very capable, excellent safety)
# Setup: https://console.anthropic.com/
# Speed: ~2-3s responses
# Cost: ~$0.003-0.030 per request (very cheap!)
# Best for: Production, nuanced reasoning, long context
ANTHROPIC_API_KEY=

# xAI Grok (fast, powerful reasoning)
# Setup: https://console.x.ai
# Speed: ~1-2s responses
# Cost: Pay-as-you-go (NO free tier - you MUST add payment method)
# Pricing: Similar to OpenAI (~$0.005-0.30 per request depending on model)
# Best for: Fast reasoning, real-time capabilities
XAI_API_KEY=
GROK_MODEL=grok-2

# =============================================================
# LLM CONFIGURATION
# =============================================================

# Which provider to use (if not specified in code)
# Valid: ollama, openai, azure_openai, anthropic, openrouter, groq, together, google, xai, huggingface, mistral, cohere, cloudflare
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2

# =============================================================
# OPTIONAL: Neo4j Memory & Persistence
# =============================================================
# Chat works perfectly without Neo4j!
# Neo4j adds memory, conversation history, and search.
# To set up: docker run -d -p 7474:7474 -p 7687:7687 neo4j
# Or skip it - chat still works fine!

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=Brain2026
# Neo4j HTTP URL (for health checks)
NEO4J_HTTP_URL=http://localhost:7474/db/neo4j/

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard
DASHBOARD_ENABLED=true

# Logging
LOG_LEVEL=INFO

# Audit Logging
AUDIT_ENABLED=true
AUDIT_LOG_FILE=/var/log/agentic-brain/audit.log
AUDIT_LOG_LEVEL=INFO

# Session Storage
# SESSION_BACKEND: memory (default) or redis
# - memory: In-memory storage, suitable for dev/small deployments
# - redis: Redis-backed storage, recommended for production/multi-instance
SESSION_BACKEND=memory
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=BrainRedis2026
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
SESSION_MAX_AGE=3600

# Authentication (optional - disabled by default)
# Set AUTH_ENABLED=true to require authentication
AUTH_ENABLED=false
# Comma-separated list of valid API keys
API_KEYS=key1,key2,key3
# JWT configuration (required if using JWT auth)
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# Firebase Transport (optional)
# Get credentials from Firebase Console > Project Settings > Service Accounts
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_CREDENTIALS=/path/to/firebase-credentials.json

# Firebase Emulator hosts (for local development)
FIREBASE_AUTH_HOST=localhost
FIREBASE_FIRESTORE_HOST=localhost
FIREBASE_DATABASE_HOST=localhost
FIREBASE_STORAGE_HOST=localhost
FIREBASE_FUNCTIONS_HOST=localhost
FIREBASE_PUBSUB_HOST=localhost

# Vector Database (optional - for similarity search)
QDRANT_URL=http://localhost:6333
WEAVIATE_URL=http://localhost:8080

# LDAP Authentication (optional)
LDAP_SERVER=ldap://localhost
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# SAML SSO (optional)
SAML_ACS_URL=http://localhost:8000/auth/saml/acs

# Security Headers
# CORS_ORIGINS: Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# CSP_STRICT: Set to 'true' to disable unsafe-inline (requires external CSS)
CSP_STRICT=false
# CSP_POLICY: Override entire Content-Security-Policy header (advanced)
# CSP_POLICY=default-src 'self'; script-src 'self'

# =============================================================
# SSL/TLS Configuration (for HTTPS)
# =============================================================
# Enable HTTPS (default: false for development)
SSL_ENABLED=false

# SSL Certificate paths (required if SSL_ENABLED=true)
# For production, use certificates from Let's Encrypt, your CA, or self-signed
SSL_CERT_FILE=/path/to/cert.pem
SSL_KEY_FILE=/path/to/key.pem

# Self-signed certificate generation (for development/testing):
#   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes
#
# Or use mkcert for local development:
#   choco install mkcert  (Windows)
#   mkcert -install
#   mkcert localhost 127.0.0.1 ::1

# Skip SSL verification for development (NOT for production!)
# Set to true if using self-signed certs with Ollama/other services
SSL_VERIFY=true

# Corporate proxy/CA bundle (for enterprise environments)
# REQUESTS_CA_BUNDLE=/path/to/corporate-ca-bundle.crt
# SSL_CERT_DIR=/etc/ssl/certs

# =============================================================
# Cartesia TTS Configuration (Optional - 40ms TTFA Cloud TTS)
# =============================================================
# Get your API key from: https://play.cartesia.ai/
# CARTESIA_API_KEY=your_api_key_here

# Default voice ID (find voices at https://play.cartesia.ai/voices)
# CARTESIA_VOICE_ID=your_preferred_voice_id
