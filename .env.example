# Agentic Brain environment configuration
# Copy to .env and customize.

# Active profile
BRAIN_PROFILE=development
# BRAIN_CONFIG_FILE=brain-config.yaml
# BRAIN_ENV_FILE=.env.local

# Application
APP_NAME=Agentic Brain
APP_VERSION=3.1.1
DEBUG=true

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_RELOAD=true
SERVER_DOCS_ENABLED=true
SERVER_BASE_PATH=/api
SERVER_REQUEST_TIMEOUT_SECONDS=60
SERVER_CORS_ORIGINS=http://localhost:3000

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_ENCRYPTED=false

# LLM
LLM_DEFAULT_PROVIDER=ollama
LLM_DEFAULT_MODEL=llama3.2:3b
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.7
OLLAMA_HOST=http://localhost:11434
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
XAI_API_KEY=

# Voice
VOICE_ENABLED=true
VOICE_PROVIDER=system
VOICE_DEFAULT_VOICE=Karen
VOICE_RATE=160
VOICE_VOLUME=0.8
VOICE_QUEUE_ENABLED=true

# Security
SECURITY_JWT_SECRET=change-me-in-production-use-a-strong-secret
SECURITY_JWT_ALGORITHM=HS512
SECURITY_JWT_EXPIRATION_HOURS=24
SECURITY_JWT_REFRESH_EXPIRATION_DAYS=7
SECURITY_PASSWORD_MIN_LENGTH=12
SECURITY_API_KEY_HEADER=X-API-Key
SECURITY_CORS_ENABLED=true
SECURITY_ALLOWED_ORIGINS=http://localhost:3000
SECURITY_RATE_LIMIT_REQUESTS=100
SECURITY_REQUIRE_AUTH=true
SECURITY_SECRETS_SOURCE=environment
CORS_ORIGINS=http://localhost:3000

# Observability
OBSERVABILITY_ENABLE_TRACING=true
OBSERVABILITY_ENABLE_METRICS=true
OBSERVABILITY_LOG_LEVEL=DEBUG
OBSERVABILITY_LOG_FORMAT=text
OBSERVABILITY_SERVICE_NAME=agentic-brain

# Cache
CACHE_BACKEND=memory
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TTL=3600
CACHE_MAX_SIZE=10000
CACHE_SEMANTIC_CACHE_ENABLED=false
CACHE_SEMANTIC_SIMILARITY_THRESHOLD=0.95

# Feature flags
FEATURE_RAG_ENABLED=true
FEATURE_VOICE_ENABLED=true
FEATURE_NEO4J_ENABLED=true
FEATURE_API_ENABLED=true
FEATURE_OBSERVABILITY_ENABLED=true
FEATURE_LOCAL_LLM_ENABLED=true
