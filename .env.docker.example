# Agentic Brain Docker Environment Example
# Copy to .env.docker and customize for your environment.
# 
# ⚠️  SECURITY WARNING: Never commit .env.docker with real passwords!
#     Use strong, unique passwords for all services.

# ---------------------------------------------------------------------------
# Core Application
# ---------------------------------------------------------------------------
ENVIRONMENT=prod                     # Application environment: prod|dev|test
DEBUG=false                          # Enable verbose logging in development
OBSERVABILITY_LOG_LEVEL=INFO         # Logging level: DEBUG|INFO|WARNING|ERROR
OBSERVABILITY_LOG_FORMAT=json        # Log format: json|console

# ---------------------------------------------------------------------------
# Neo4j Graph Database
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687          # Bolt URI used by the app
NEO4J_USER=neo4j                     # Neo4j username
NEO4J_PASSWORD=Brain2026                      # REQUIRED: Set a strong password (min 12 chars)
NEO4J_DATABASE=neo4j                 # Default database name

# ---------------------------------------------------------------------------
# Redis Cache / Message Broker
# ---------------------------------------------------------------------------
REDIS_HOST=redis                     # Redis host (service name in Docker network)
REDIS_PORT=6379                      # Redis port
REDIS_PASSWORD=                      # REQUIRED: Set a strong password (min 12 chars)
REDIS_DB=0                           # Redis database index

# ---------------------------------------------------------------------------
# Redpanda / Kafka Event Bus
# ---------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092   # Kafka-compatible bootstrap servers

# ---------------------------------------------------------------------------
# Security / Auth
# ---------------------------------------------------------------------------
JWT_SECRET=                          # REQUIRED: Generate with: openssl rand -hex 32

# ---------------------------------------------------------------------------
# LLM Providers (optional)
# ---------------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=ollama          # Default LLM provider: ollama|openai|anthropic|groq|gemini
OPENAI_API_KEY=                      # Optional: OpenAI API key
ANTHROPIC_API_KEY=                   # Optional: Anthropic API key
GEMINI_API_KEY=                      # Optional: Google Gemini API key
GROQ_API_KEY=                        # Optional: Groq API key

# ---------------------------------------------------------------------------
# Misc / Tuning (optional)
# ---------------------------------------------------------------------------
NEO4J_MAX_CONNECTIONS=50             # Max Neo4j connection pool size
NEO4J_CONNECTION_TIMEOUT=30          # Neo4j connection timeout (seconds)
REDIS_MAX_CONNECTIONS=20             # Max Redis connection pool size
COMPOSE_PROJECT_NAME=agentic-brain   # Optional: override Docker Compose project name
