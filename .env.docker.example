# Agentic Brain Docker Environment Example
# ============================================================================
# Copy to .env.docker and customize for your Docker deployment.
#
# ⚠️  SECURITY WARNING: Never commit real credentials!
#     - Generate strong, unique passwords for production deployments
#     - Use `openssl rand -hex 32` to generate secure tokens
#     - Rotate credentials regularly
#     - Use Docker secrets for sensitive data in production clusters
# ============================================================================

# ---------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ---------------------------------------------------------------------------
ENVIRONMENT=production                    # Environment: production|staging|development
DEBUG=false                               # Enable debug logging (false for production)
OBSERVABILITY_LOG_LEVEL=INFO              # Log level: DEBUG|INFO|WARNING|ERROR|CRITICAL
OBSERVABILITY_LOG_FORMAT=json             # Format: json (structured) or console (human-readable)

# ---------------------------------------------------------------------------
# DOCKER-SPECIFIC NETWORK SETTINGS
# ⚠️  CRITICAL: Use service names, NOT localhost!
# ---------------------------------------------------------------------------

# Neo4j Graph Database (service name: neo4j)
NEO4J_URI=bolt://neo4j:7687               # Connect via internal Docker network
NEO4J_USER=neo4j                          # Database username
NEO4J_PASSWORD=your-neo4j-password-here   # REQUIRED: Min 12 chars, strong password
NEO4J_DATABASE=neo4j                      # Default database name
NEO4J_MAX_CONNECTIONS=50                  # Connection pool size
NEO4J_CONNECTION_TIMEOUT=30               # Connection timeout in seconds
NEO4J_ENCRYPTION=true                     # Enable bolt encryption (recommended)

# Redis Cache & Message Queue (service name: redis)
REDIS_HOST=redis                          # Connect via internal Docker network
REDIS_PORT=6379                           # Standard Redis port
REDIS_PASSWORD=your-redis-password-here   # REQUIRED: Min 12 chars, strong password
REDIS_DB=0                                # Database index (0-15)
REDIS_MAX_CONNECTIONS=20                  # Connection pool size

# Redpanda / Kafka Event Bus (service name: redpanda)
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092     # Kafka broker addresses (internal network)

# ---------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ---------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-key-here       # REQUIRED: Generate with: openssl rand -hex 32
JWT_EXPIRATION_HOURS=24                   # Token expiration time
JWT_REFRESH_ENABLED=true                  # Enable refresh token rotation

# SSL/TLS for Corporate Networks (optional)
# Use these settings if your corporate network requires certificate validation
USE_SSL_CERT_VERIFICATION=true            # Verify SSL certificates
# SSL_CERT_PATH=/etc/ssl/certs/ca-bundle.crt  # Optional: path to custom CA bundle
# SSL_VERIFY_HOSTNAME=true                 # Verify hostname in certificates

# Network Security (optional)
# CORPORATE_PROXY_URL=http://proxy.corp:8080  # Optional: corporate proxy
# NO_PROXY=redis,neo4j,redpanda               # Services to bypass proxy

# ---------------------------------------------------------------------------
# LLM PROVIDERS (Use placeholder values, no real keys!)
# ---------------------------------------------------------------------------

# Primary/Default Provider
DEFAULT_LLM_PROVIDER=ollama               # Default: ollama|openai|anthropic|groq|gemini|together|cohere

# Ollama (Local LLM - highly recommended for Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434  # Ollama running on host machine
OLLAMA_MODEL=mistral                      # Model to use: mistral, llama2, neural-chat, etc.

# OpenAI (optional)
OPENAI_API_KEY=sk-your-openai-key-here   # Format: sk-***
OPENAI_MODEL=gpt-4-turbo                  # Model version
OPENAI_TIMEOUT=60                         # API timeout in seconds

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=sk-ant-your-key-here    # Format: sk-ant-***
ANTHROPIC_MODEL=claude-3-opus-20240229    # Model version

# Google Gemini (optional)
GEMINI_API_KEY=AIzaSy-your-gemini-key     # Format: AIzaSy-***
GEMINI_MODEL=gemini-pro                   # Model version

# Groq (optional - fast inference)
GROQ_API_KEY=gsk_your-groq-key-here       # Format: gsk_***
GROQ_MODEL=mixtral-8x7b-32768            # Model version

# Together AI (optional)
TOGETHER_API_KEY=your-together-key-here   # API key for Together.ai

# Cohere (optional)
COHERE_API_KEY=your-cohere-key-here       # API key for Cohere

# HuggingFace (optional)
HUGGINGFACE_API_KEY=hf_your-key-here      # Format: hf_***
HUGGINGFACE_MODEL_ID=your-model-id        # Model ID from HuggingFace Hub

# ---------------------------------------------------------------------------
# VOICE & AUDIO SETTINGS (optional)
# ---------------------------------------------------------------------------
VOICE_ENABLED=true                        # Enable voice features
VOICE_PROVIDER=elevenlabs                 # Provider: elevenlabs, azure, google, apple
VOICE_MODEL=eleven_monolingual_v1         # Voice model
# ELEVENLABS_API_KEY=your-elevenlabs-key   # Optional: ElevenLabs API key

# ---------------------------------------------------------------------------
# PERFORMANCE & RESOURCE LIMITS
# ---------------------------------------------------------------------------

# Connection Pools
NEO4J_POOL_SIZE=50                        # Neo4j pool size
REDIS_POOL_SIZE=20                        # Redis pool size

# Request Timeouts (seconds)
DEFAULT_REQUEST_TIMEOUT=30                # Default API timeout
LLM_REQUEST_TIMEOUT=120                   # LLM API timeout (longer for large models)
DATABASE_QUERY_TIMEOUT=45                 # Database query timeout

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=true                   # Enable API rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60         # Requests per minute
RATE_LIMIT_BURST_SIZE=10                  # Burst size

# ---------------------------------------------------------------------------
# DOCKER COMPOSE SETTINGS
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=agentic-brain        # Project name (appears in container names)
DOCKER_NETWORK=agentic-brain-network      # Docker network name

# ---------------------------------------------------------------------------
# MONITORING & OBSERVABILITY (optional)
# ---------------------------------------------------------------------------
METRICS_ENABLED=true                      # Enable Prometheus metrics
METRICS_PORT=9090                         # Metrics port (inside container)
TRACING_ENABLED=false                     # Enable distributed tracing (Jaeger, etc.)
# JAEGER_ENDPOINT=http://jaeger:6831      # Jaeger agent endpoint (if enabled)

# ---------------------------------------------------------------------------
# FEATURE FLAGS (optional)
# ---------------------------------------------------------------------------
FEATURE_MEMORY_ENABLED=true               # Enable long-term memory (Neo4j)
FEATURE_CACHING_ENABLED=true              # Enable caching (Redis)
FEATURE_EVENT_BUS_ENABLED=true            # Enable event bus (Kafka/Redpanda)
FEATURE_VOICE_ENABLED=true                # Enable voice features
FEATURE_LLAMA_FALLBACK=true               # Fall back to Ollama if primary LLM fails

# ---------------------------------------------------------------------------
# DEVELOPMENT/DEBUGGING (optional - set DEBUG=true above to enable)
# ---------------------------------------------------------------------------
# VERBOSE_LOGGING=false                   # Extra verbose logs for debugging
# PROFILE_QUERIES=false                   # Log slow database queries
# DUMP_REQUEST_RESPONSES=false             # Log all API requests/responses (VERBOSE!)
# TEST_MODE=false                          # Enable test mode
