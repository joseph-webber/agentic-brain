{
  "apiVersion": 3,
  "name": "agentic-brain/product-search",
  "title": "AI Product Search",
  "category": "widgets",
  "icon": "search",
  "description": "Smart product search with AI suggestions",
  "attributes": {
    "placeholder": {
      "type": "string",
      "default": "Search for products..."
    },
    "enableVoice": {
      "type": "boolean",
      "default": true
    },
    "displayMode": {
      "type": "string",
      "default": "grid"
    },
    "limit": {
      "type": "number",
      "default": 6
    }
  },
  "textdomain": "agentic-brain",
  "editorScript": "file:../../build/index.js",
  "style": "file:../../build/style-index.css"
}